{
  "agents": {
    "defaults": {
      "workspace": "workspace",
      "model": {
        "primary": "ollama/qwen2.5:3b"
      },
      "models": {
        "ollama/qwen2.5:3b": {}
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "lygo-usb-standalone-token"
    },
    "port": 18789,
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "null",
        "file:",
        "file://",
        "*"
      ],
      "allowInsecureAuth": true
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "api": "ollama",
        "apiKey": "OLLAMA_API_KEY"
      }
    }
  },
  "plugins": {
    "entries": {
      "ollama": {
        "enabled": true,
        "config": {
          "discovery": {
            "enabled": true
          }
        }
      }
    }
  }
}